rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // USERS COLLECTION
    // =========================================
    match /users/{userId} {
      // Anyone authenticated can read profiles (for browsing)
      allow read: if request.auth != null;

      // Only the authenticated user can create/update their own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // Only the user themselves can delete their account
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // =========================================
    // REQUESTS COLLECTION
    // =========================================
    match /requests/{requestId} {
      // Users can read requests involving themselves
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      // Authenticated users can create requests (as the sender)
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.fromUid != request.resource.data.toUid;

      // Only the recipient can update status (accept/reject)
      // Sender can delete (cancel) their own pending request
      allow update: if request.auth != null && (
        (resource.data.toUid == request.auth.uid) ||
        (resource.data.fromUid == request.auth.uid && resource.data.status == 'pending')
      );

      allow delete: if request.auth != null &&
        resource.data.fromUid == request.auth.uid;
    }

    // =========================================
    // CHATS COLLECTION
    // =========================================
    match /chats/{chatId} {
      // Only participants can read and write to a chat
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // ---- Messages sub-collection ----
      match /messages/{messageId} {
        // Only chat participants can read messages
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Only authenticated participants can send messages
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderUid == request.auth.uid;

        // Messages cannot be edited or deleted
        allow update, delete: if false;
      }
    }

    // =========================================
    // RATINGS COLLECTION
    // =========================================
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }

    // =========================================
    // POSTS COLLECTION (Feed + Progress updates)
    // =========================================
    match /posts/{postId} {
      allow read: if request.auth != null;

      // Only the author can create a post
      allow create: if request.auth != null &&
        request.resource.data.authorUid == request.auth.uid;

      // Author can fully update / delete their own post
      allow update: if request.auth != null && (
        resource.data.authorUid == request.auth.uid ||
        // Any auth'd user may increment likes or commentCount only
        (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likes', 'commentCount']))
      );

      allow delete: if request.auth != null &&
        resource.data.authorUid == request.auth.uid;

      // ---- Comments sub-collection ----
      match /comments/{commentId} {
        // Any authenticated user can read comments
        allow read: if request.auth != null;

        // Authenticated users can post a comment as themselves
        allow create: if request.auth != null &&
          request.resource.data.authorUid == request.auth.uid;

        // Only the comment author can delete their own comment
        allow delete: if request.auth != null &&
          resource.data.authorUid == request.auth.uid;

        // Comments cannot be edited
        allow update: if false;
      }
    }

    // =========================================
    // SESSIONS COLLECTION (Scheduling)
    // =========================================
    match /sessions/{sessionId} {
      // Only participants can read their sessions
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Any authenticated user can create a session they are part of
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // Only participants can update (e.g., cancel) a session
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Only the creator can delete a session
      allow delete: if request.auth != null &&
        resource.data.createdBy == request.auth.uid;
    }

    // =========================================
    // NOTIFICATIONS COLLECTION (Future use)
    // =========================================
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
  }
}
