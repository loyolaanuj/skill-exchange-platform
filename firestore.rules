rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================
    // USERS COLLECTION
    // =========================================
    match /users/{userId} {
      // Anyone authenticated can read profiles (for browsing)
      allow read: if request.auth != null;

      // Only the authenticated user can create/update their own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // Only the user themselves can delete their account
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // =========================================
    // REQUESTS COLLECTION
    // =========================================
    match /requests/{requestId} {
      // Users can read requests involving themselves
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);

      // Authenticated users can create requests (as the sender)
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid &&
        request.resource.data.fromUid != request.resource.data.toUid;

      // Only the recipient can update status (accept/reject)
      // Sender can delete (cancel) their own pending request
      allow update: if request.auth != null && (
        (resource.data.toUid == request.auth.uid) ||
        (resource.data.fromUid == request.auth.uid && resource.data.status == 'pending')
      );

      allow delete: if request.auth != null &&
        resource.data.fromUid == request.auth.uid;
    }

    // =========================================
    // CHATS COLLECTION
    // =========================================
    match /chats/{chatId} {
      // Only participants can read and write to a chat
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // ---- Messages sub-collection ----
      match /messages/{messageId} {
        // Only chat participants can read messages
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Only authenticated participants can send messages
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderUid == request.auth.uid;

        // Messages cannot be edited or deleted
        allow update, delete: if false;
      }
    }

    // =========================================
    // RATINGS COLLECTION (optional)
    // =========================================
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
